                        profileImage,
                      },
                    });
                  }
                  if (itemName === "Spotlight")
                    router.push("/(tabs)/TeacherDashBoard/SpotlightTarrif");
                  if (itemName === "Share") {
                    router.push({
                      pathname: "/(tabs)/TeacherDashBoard/Share",
