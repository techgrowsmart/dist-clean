# Production Environment Configuration for Gogrowsmart Portal

# Production Backend API URL - use production backend for local development
EXPO_PUBLIC_API_URL=https://growsmartserver.gogrowsmart.com

# Production Frontend Domain
EXPO_PUBLIC_DOMAIN=portal.gogrowsmart.com
EXPO_PUBLIC_BASE_URL=https://portal.gogrowsmart.com

# Development mode flag (set to false for production)
EXPO_PUBLIC_DEV_MODE=false

# Production Razor Pay Key (using test key for now)
EXPO_PUBLIC_RAZORPAY_KEY=rzp_test_RY9WNGFa44XzaQ

# Production WebSocket URL (Backend)
EXPO_PUBLIC_WS_URL=wss://growsmartserver.gogrowsmart.com

# Environment flag
NODE_ENV=production

# Analytics and monitoring
EXPO_PUBLIC_ANALYTICS_ENABLED=true

# Production features
EXPO_PUBLIC_DEBUG_MODE=false
EXPO_PUBLIC_LOG_LEVEL=error

# Backend Database Configuration
# MongoDB Connection String (replace with production MongoDB URI)
MONGODB_URI=mongodb://admin:YOUR_PASSWORD@production-mongodb-host:27017/growsmart_production?authSource=admin

# Redis Connection String (replace with production Redis URI)
REDIS_URL=redis://:YOUR_PASSWORD@production-redis-host:6379

# Backend Server Port
PORT=3000
